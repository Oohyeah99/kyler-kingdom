{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/generate-image.ts": {
      "maxDuration": 120
    },
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets/)(?!pattern-phonics\\.html).*)", "destination": "/index.html" }
  ]
}
